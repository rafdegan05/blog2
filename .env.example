# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/blogpodcast?schema=public"

# NextAuth v5
NEXTAUTH_URL="http://localhost:3000"
AUTH_SECRET="generate-a-random-secret-here"  # npx auth secret

# OAuth Providers (optional - configure with your own credentials)

# GitHub
GITHUB_ID=""
GITHUB_SECRET=""

# Google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Keycloak
KEYCLOAK_ISSUER=""
KEYCLOAK_CLIENT_ID=""
KEYCLOAK_CLIENT_SECRET=""

# AWS S3 (file uploads)
AWS_S3_BUCKET=""
AWS_S3_REGION=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
