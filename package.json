{
  "name": "bl-fs",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "npx prisma generate && next build",
    "start": "next start",
    "lint": "eslint . --fix",
    "format": "prettier --write .",
    "prepare": "husky",
    "db:generate": "npx prisma generate",
    "db:migrate": "npx prisma migrate dev",
    "db:push": "npx prisma db push",
    "db:studio": "npx prisma studio",
    "db:seed": "npx tsx prisma/seed.ts",
    "release": "standard-version",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "docker:setup": "powershell -ExecutionPolicy Bypass -File ./scripts/docker.ps1 setup",
    "docker:up": "powershell -ExecutionPolicy Bypass -File ./scripts/docker.ps1 up",
    "docker:down": "powershell -ExecutionPolicy Bypass -File ./scripts/docker.ps1 down",
    "docker:build": "powershell -ExecutionPolicy Bypass -File ./scripts/docker.ps1 build",
    "docker:dev": "powershell -ExecutionPolicy Bypass -File ./scripts/docker.ps1 dev",
    "docker:logs": "powershell -ExecutionPolicy Bypass -File ./scripts/docker.ps1 logs",
    "docker:ps": "powershell -ExecutionPolicy Bypass -File ./scripts/docker.ps1 ps",
    "docker:clean": "powershell -ExecutionPolicy Bypass -File ./scripts/docker.ps1 clean"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "daisyui": "^5.5.19",
    "dotenv": "^17.3.1",
    "next": "16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "pg": "^8.20.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/pg": "^8.18.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "prisma": "^7.4.2",
    "semantic-release": "^25.0.3",
    "standard-version": "^9.5.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
